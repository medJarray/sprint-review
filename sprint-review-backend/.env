# ─── Sprint Review Backend ───
# Connexion MongoDB (avec credentials Docker)
MONGODB_URI=mongodb://admin:admin123@localhost:27017/sprint-review?authSource=admin

# Port du serveur
PORT=3001

# Origine CORS autorisée (frontend)
